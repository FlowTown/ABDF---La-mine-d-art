<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>La Mine d'Art</title>
  <style>
    :root {
      --bg: #111111;
      --panel: #1b1b1b;
      --panel-2: #242424;
      --text: #f4f0e8;
      --muted: #c8c0b3;
      --accent: #c8a96b;
      --accent-2: #e6cf9d;
      --border: rgba(255,255,255,0.08);
      --shadow: 0 12px 40px rgba(0,0,0,0.28);
      --radius: 22px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top right, rgba(200,169,107,0.14), transparent 20%),
        linear-gradient(180deg, #0d0d0d 0%, #121212 100%);
      color: var(--text);
    }

    a { color: inherit; text-decoration: none; }
    button { font: inherit; }

    .layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      min-height: 100vh;
    }

    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      padding: 28px 20px;
      border-right: 1px solid var(--border);
      background: rgba(12,12,12,0.9);
      backdrop-filter: blur(12px);
    }

    .brand {
      padding: 18px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
      box-shadow: var(--shadow);
      margin-bottom: 20px;
    }

    .brand small {
      display: inline-block;
      color: var(--accent-2);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-size: 11px;
      margin-bottom: 10px;
    }

    .brand h1 {
      margin: 0;
      font-size: 30px;
      line-height: 1;
    }

    .brand p {
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .nav {
      margin-top: 18px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .nav-section {
      border: 1px solid var(--border);
      border-radius: 18px;
      overflow: hidden;
      background: rgba(255,255,255,0.02);
    }

    .nav-link,
    .nav-toggle,
    .submenu a {
      width: 100%;
      display: block;
      padding: 14px 16px;
      border: 0;
      background: transparent;
      color: var(--text);
      text-align: left;
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    }

    .nav-link:hover,
    .nav-toggle:hover,
    .submenu a:hover {
      background: rgba(200,169,107,0.08);
      color: var(--accent-2);
    }

    .nav-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-weight: 600;
    }

    .submenu {
      border-top: 1px solid var(--border);
      display: none;
      background: rgba(0,0,0,0.14);
    }

    .nav-section.open .submenu {
      display: block;
    }

    .submenu a {
      padding-left: 28px;
      color: var(--muted);
      font-size: 14px;
    }

    .sidebar-footer {
      margin-top: 18px;
      padding: 16px;
      border-radius: 18px;
      background: rgba(200,169,107,0.08);
      border: 1px solid rgba(200,169,107,0.18);
    }

    .sidebar-footer p {
      margin: 0 0 12px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .sidebar-footer a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 14px;
      border-radius: 12px;
      background: var(--accent);
      color: #17130d;
      font-weight: 700;
    }

    .content {
      padding: 28px;
    }

    .section {
      border: 1px solid var(--border);
      border-radius: 30px;
      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
      padding: 28px;
      margin-bottom: 24px;
      box-shadow: var(--shadow);
    }

    .hero {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 24px;
      align-items: stretch;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 14px;
      color: var(--accent-2);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 12px;
      font-weight: 700;
    }

    h2 {
      margin: 0 0 14px;
      font-size: clamp(32px, 4vw, 56px);
      line-height: 0.95;
    }

    h3 {
      margin: 0 0 10px;
      font-size: 24px;
    }

    p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }

    .hero-copy p {
      font-size: 17px;
      max-width: 62ch;
    }

    .hero-actions {
      display: flex;
      gap: 12px;
      margin-top: 22px;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 18px;
      border-radius: 14px;
      border: 1px solid var(--border);
      color: var(--text);
      background: rgba(255,255,255,0.02);
      font-weight: 700;
    }

    .btn.primary {
      background: var(--accent);
      color: #17130d;
      border-color: transparent;
    }

    .hero-card {
      border-radius: 26px;
      overflow: hidden;
      min-height: 340px;
      background:
        linear-gradient(160deg, rgba(200,169,107,0.18), rgba(255,255,255,0.04)),
        url('https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1200&q=80') center/cover;
      position: relative;
      border: 1px solid var(--border);
    }

    .hero-badge {
      position: absolute;
      left: 18px;
      bottom: 18px;
      right: 18px;
      padding: 18px;
      border-radius: 18px;
      background: rgba(0,0,0,0.55);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .grid-3,
    .grid-2,
    .catalog-grid {
      display: grid;
      gap: 18px;
    }

    .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .catalog-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }

    .card {
      padding: 22px;
      border: 1px solid var(--border);
      border-radius: 22px;
      background: rgba(255,255,255,0.02);
    }

    .card strong {
      display: block;
      margin-bottom: 8px;
      font-size: 18px;
    }

    .mini-title {
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .mini-title p {
      max-width: 58ch;
    }

    .filters {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    .filter-btn {
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.03);
      color: var(--text);
      cursor: pointer;
      transition: 0.2s ease;
    }

    .filter-btn.active,
    .filter-btn:hover {
      background: var(--accent);
      color: #17130d;
      border-color: transparent;
    }

    .product-card {
      overflow: hidden;
      border-radius: 24px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.02);
    }

    .product-card img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      display: block;
    }

    .product-body {
      padding: 18px;
    }

    .product-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(200,169,107,0.12);
      border: 1px solid rgba(200,169,107,0.18);
      color: var(--accent-2);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .contact-box {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .contact-card,
    .contact-form {
      padding: 22px;
      border-radius: 24px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.02);
    }

    .contact-form form {
      display: grid;
      gap: 12px;
    }

    input, textarea {
      width: 100%;
      padding: 14px 15px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: #151515;
      color: var(--text);
      font: inherit;
    }

    textarea {
      min-height: 140px;
      resize: vertical;
    }

    .mobile-topbar {
      display: none;
      position: sticky;
      top: 0;
      z-index: 20;
      padding: 14px 16px;
      backdrop-filter: blur(12px);
      background: rgba(10,10,10,0.92);
      border-bottom: 1px solid var(--border);
      justify-content: space-between;
      align-items: center;
    }

    .mobile-topbar button {
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.04);
      color: var(--text);
    }

    @media (max-width: 1100px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        width: min(86vw, 340px);
        z-index: 40;
        transform: translateX(-100%);
        transition: transform 0.25s ease;
      }
      .sidebar.open { transform: translateX(0); }
      .mobile-topbar { display: flex; }
      .content { padding: 18px; }
      .hero { grid-template-columns: 1fr; }
      .grid-3, .grid-2, .catalog-grid, .contact-box { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="mobile-topbar">
    <strong>La Mine d'Art</strong>
    <button id="menuButton">☰ Menu</button>
  </div>

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <div class="brand">
        <small>Ressourcerie événementielle</small>
        <h1>La Mine d'Art</h1>
        <p>Décors, mobilier, accessoires et matières pour donner une seconde vie aux éléments de l'événementiel.</p>
      </div>

      <nav class="nav">
        <div class="nav-section">
          <a class="nav-link" href="#accueil">Accueil</a>
        </div>

        <div class="nav-section open">
          <button class="nav-toggle">Location <span>＋</span></button>
          <div class="submenu">
            <a href="#location">Comment ça marche</a>
            <a href="#engagements">Engagements</a>
          </div>
        </div>

        <div class="nav-section open">
          <button class="nav-toggle">Catalogue <span>＋</span></button>
          <div class="submenu">
            <a href="#catalogue" data-filter-link="all">Tout voir</a>
            <a href="#catalogue" data-filter-link="mobilier">Mobilier</a>
            <a href="#catalogue" data-filter-link="decors">Décors</a>
            <a href="#catalogue" data-filter-link="accessoires">Accessoires</a>
            <a href="#catalogue" data-filter-link="lumieres">Lumières</a>
          </div>
        </div>

        <div class="nav-section">
          <a class="nav-link" href="#contact">Contact</a>
        </div>
      </nav>

      <div class="sidebar-footer">
        <p>Besoin d'un décor, d'un lot ou d'une scénographie ? On prépare une sélection adaptée à ton événement.</p>
        <a href="#contact">Demander un devis</a>
      </div>
    </aside>

    <main class="content">
      <section class="section hero" id="accueil">
        <div class="hero-copy">
          <span class="eyebrow">Récupérer • Transformer • Louer</span>
          <h2>Une ressourcerie pensée pour l'événementiel.</h2>
          <p>
            La Mine d'Art centralise du mobilier, des décors, des accessoires et des éléments scénographiques pour aider les structures, artistes et organisateurs à créer plus beau, plus vite, et avec plus de sens.
          </p>
          <div class="hero-actions">
            <a class="btn primary" href="#catalogue">Voir le catalogue</a>
            <a class="btn" href="#location">Découvrir la location</a>
          </div>
        </div>

        <div class="hero-card">
          <div class="hero-badge">
            <strong>Un stock évolutif pour les projets culturels, festifs et scénographiques.</strong>
            <p style="margin-top: 8px;">Mobilier, accessoires, habillage, matières, structures, lumière et pépites de récup' prêtes à repartir sur le terrain.</p>
          </div>
        </div>
      </section>

      <section class="section" id="location">
        <div class="mini-title">
          <div>
            <span class="eyebrow">Location</span>
            <h3>Comment ça marche</h3>
          </div>
          <p>Le principe est simple : tu repères les éléments qui t'intéressent, tu nous contactes, et on prépare une proposition adaptée à ton besoin.</p>
        </div>

        <div class="grid-3">
          <div class="card">
            <strong>1. Sélection</strong>
            <p>Tu explores le catalogue par catégorie et tu repères les pièces qui peuvent servir à ton décor, ton stand, ton événement ou ta scénographie.</p>
          </div>
          <div class="card">
            <strong>2. Demande</strong>
            <p>Tu nous écris avec les quantités, les dates et le contexte de ton projet. On te répond avec les disponibilités et les conditions.</p>
          </div>
          <div class="card">
            <strong>3. Retrait / mise à dispo</strong>
            <p>Une fois validé, on organise le retrait, la mise de côté ou une solution adaptée selon la nature du projet.</p>
          </div>
        </div>
      </section>

      <section class="section" id="engagements">
        <div class="mini-title">
          <div>
            <span class="eyebrow">Projet</span>
            <h3>Pourquoi La Mine d'Art</h3>
          </div>
          <p>Une logique de réemploi au service de la création, de la production et de l'événementiel.</p>
        </div>

        <div class="grid-2">
          <div class="card">
            <strong>Seconde vie des éléments</strong>
            <p>Plutôt que de laisser dormir du matériel, l'idée est de remettre en circulation des éléments utiles, singuliers et exploitables dans de nouveaux projets.</p>
          </div>
          <div class="card">
            <strong>Gain de temps créatif</strong>
            <p>Le catalogue permet de trouver rapidement une base visuelle ou technique sans repartir de zéro à chaque production.</p>
          </div>
        </div>
      </section>

      <section class="section" id="catalogue">
        <div class="mini-title">
          <div>
            <span class="eyebrow">Catalogue</span>
            <h3>Explorer par catégorie</h3>
          </div>
          <p>Voici une première maquette catalogue. Les fiches seront ensuite reliées à ton vrai inventaire.</p>
        </div>

        <div class="filters">
          <button class="filter-btn active" data-filter="all">Tout</button>
          <button class="filter-btn" data-filter="mobilier">Mobilier</button>
          <button class="filter-btn" data-filter="decors">Décors</button>
          <button class="filter-btn" data-filter="accessoires">Accessoires</button>
          <button class="filter-btn" data-filter="lumieres">Lumières</button>
        </div>

        <div class="catalog-grid" id="catalogGrid">
          <article class="product-card" data-category="mobilier">
            <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=900&q=80" alt="Chaise vintage" />
            <div class="product-body">
              <div class="product-top">
                <strong>Chaise vintage bois</strong>
                <span class="pill">Mobilier</span>
              </div>
              <p>Parfaite pour scénographie, coin photo, habillage de salle ou ambiance rétro chaleureuse.</p>
            </div>
          </article>

          <article class="product-card" data-category="decors">
            <img src="https://images.unsplash.com/photo-1511578314322-379afb476865?auto=format&fit=crop&w=900&q=80" alt="Décor événementiel" />
            <div class="product-body">
              <div class="product-top">
                <strong>Panneau décor texturé</strong>
                <span class="pill">Décors</span>
              </div>
              <p>Élément visuel pour fond de scène, allée d'accueil, zone photo ou mise en ambiance immersive.</p>
            </div>
          </article>

          <article class="product-card" data-category="accessoires">
            <img src="https://images.unsplash.com/photo-1512436991641-6745cdb1723f?auto=format&fit=crop&w=900&q=80" alt="Accessoires" />
            <div class="product-body">
              <div class="product-top">
                <strong>Lot de cadres dorés</strong>
                <span class="pill">Accessoires</span>
              </div>
              <p>Idéal pour scénographie poétique, parcours immersif, expo, vitrine ou décoration murale.</p>
            </div>
          </article>

          <article class="product-card" data-category="lumieres">
            <img src="https://images.unsplash.com/photo-1516383607781-913a19294fd1?auto=format&fit=crop&w=900&q=80" alt="Guirlandes lumineuses" />
            <div class="product-body">
              <div class="product-top">
                <strong>Guirlandes guinguette</strong>
                <span class="pill">Lumières</span>
              </div>
              <p>Pour patios, cours, espaces festifs ou ambiance chaleureuse en intérieur comme en extérieur.</p>
            </div>
          </article>

          <article class="product-card" data-category="mobilier">
            <img src="https://images.unsplash.com/photo-1493666438817-866a91353ca9?auto=format&fit=crop&w=900&q=80" alt="Table en bois" />
            <div class="product-body">
              <div class="product-top">
                <strong>Table atelier bois</strong>
                <span class="pill">Mobilier</span>
              </div>
              <p>Table brute et modulable pour buffet, stand, atelier créatif ou poste de scénographie.</p>
            </div>
          </article>

          <article class="product-card" data-category="accessoires">
            <img src="https://images.unsplash.com/photo-1521572267360-ee0c2909d518?auto=format&fit=crop&w=900&q=80" alt="Tissus et matières" />
            <div class="product-body">
              <div class="product-top">
                <strong>Textiles et matières</strong>
                <span class="pill">Accessoires</span>
              </div>
              <p>Rideaux, nappages, textures et habillages pour enrichir une scénographie ou un décor.</p>
            </div>
          </article>
        </div>
      </section>

      <section class="section" id="contact">
        <div class="mini-title">
          <div>
            <span class="eyebrow">Contact</span>
            <h3>Parlons de ton besoin</h3>
          </div>
          <p>Tu peux utiliser ce bloc comme base avant de le connecter à un vrai formulaire.</p>
        </div>

        <div class="contact-box">
          <div class="contact-card">
            <strong style="display:block;margin-bottom:10px;font-size:20px;">La Mine d'Art</strong>
            <p style="margin-bottom:16px;">Ressourcerie dédiée à l'événementiel, à la création visuelle et aux projets scénographiques.</p>
            <p><strong>Email :</strong> contact@laminedart.fr</p>
            <p><strong>Téléphone :</strong> 06 00 00 00 00</p>
            <p><strong>Zone :</strong> Hauts-de-France / projets sur demande</p>
          </div>

          <div class="contact-form">
            <form>
              <input type="text" placeholder="Nom / structure" />
              <input type="email" placeholder="Adresse mail" />
              <input type="text" placeholder="Date ou période souhaitée" />
              <textarea placeholder="Décris ton besoin, les éléments recherchés, les quantités, le style, etc."></textarea>
              <button type="button" class="btn primary">Envoyer la demande</button>
            </form>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script>
    const sidebar = document.getElementById('sidebar');
    const menuButton = document.getElementById('menuButton');
    const toggles = document.querySelectorAll('.nav-toggle');
    const filterButtons = document.querySelectorAll('.filter-btn');
    const filterLinks = document.querySelectorAll('[data-filter-link]');
    const cards = document.querySelectorAll('.product-card');

    menuButton?.addEventListener('click', () => {
      sidebar.classList.toggle('open');
    });

    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        toggle.parentElement.classList.toggle('open');
      });
    });

    function applyFilter(category) {
      filterButtons.forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.filter === category);
      });

      cards.forEach((card) => {
        const show = category === 'all' || card.dataset.category === category;
        card.style.display = show ? 'block' : 'none';
      });
    }

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => applyFilter(button.dataset.filter));
    });

    filterLinks.forEach((link) => {
      link.addEventListener('click', () => {
        const category = link.dataset.filterLink;
        applyFilter(category);
        if (window.innerWidth <= 1100) {
          sidebar.classList.remove('open');
        }
      });
    });

    document.querySelectorAll('.nav-link, .submenu a').forEach((link) => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 1100) {
          sidebar.classList.remove('open');
        }
      });
    });
  </script>
</body>
</html>
